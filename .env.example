# MongoDB
MONGODB_URI=your_mongodb_connection_string

# Session
SESSION_SECRET=your_session_secret

# Server Port
PORT=3000

# Cloudinary (from https://console.cloudinary.com/)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_UPLOAD_PRESET=your_unsigned_preset


# IMPORTANT: For production on Render, set these as Environment Variables
# in your Render Dashboard > Service > Environment > Environment Variables
# Do NOT commit the .env file to git (it is already in .gitignore)
